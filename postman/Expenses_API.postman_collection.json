                        "url": {
                            "raw": "{{base_url}}/expenses/{{expense_id}}",
                            "host": ["{{base_url}}"],
                            "path": ["expenses", "{{expense_id}}"]
                        },
                        "description": "Deletes an expense. Requires Admin role. Deletion is audit-logged."
                    }
                }
            ]
        },
